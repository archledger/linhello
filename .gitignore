/target
**/*.rs.bk
Cargo.lock.bak
*.onnx
# Exception: the anti-spoof models are Apache-2.0 (minivision-ai Silent-Face)
# and small (~1.9MB each), so we ship them to keep install smooth. buffalo_l
# (det_10g/face) stays user-fetched (InsightFace license).
!/models/antispoof.onnx
!/models/antispoof_4.onnx
/etc/linhello/*/embedding.bin
/etc/linhello/*/tpm_envelope.json

# Build artifacts
/pam/pam_linhello.so
# SELinux policy module build outputs (`make -C etc/selinux`; the spec rebuilds
# these at RPM-build time — they must never be committed).
*.pp
*.mod
/etc/selinux/tmp/

# Arch packaging artifacts
/packaging/arch/src/
/packaging/arch/pkg/
/packaging/arch/*.pkg.tar.zst
/packaging/arch/*.log
/packaging/arch/*.tar.gz
