#%PAM-1.0
#
# Example /etc/pam.d/gdm-password with aegyra face-auth.
#
# Install:
#   cp /usr/share/aegyra/pam.d/examples/gdm-password /etc/pam.d/gdm-password
#
# Face-auth runs first; on success PAM_AUTHTOK holds the TPM-unsealed secret
# (seeded with your login password at enroll time). pam_gnome_keyring picks
# that up via `use_authtok` and unlocks the login keyring with no second
# prompt. On face-auth failure, PAM falls through to the normal password
# path, which remains the source of truth.

auth       sufficient   pam_faceauth.so
auth       include      system-local-login
auth       optional     pam_gnome_keyring.so

account    include      system-local-login

password   include      system-local-login
password   optional     pam_gnome_keyring.so use_authtok

session    include      system-local-login
session    optional     pam_gnome_keyring.so auto_start
