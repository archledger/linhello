#%PAM-1.0
#
# Example /etc/pam.d/gdm-password with aegyra face-auth.
#
# Install:
#   sudo cp /etc/pam.d/gdm-password /etc/pam.d/gdm-password.bak
#   sudo cp /usr/share/aegyra/pam.d/examples/gdm-password /etc/pam.d/gdm-password
#
# Face-auth runs first; on success PAM_AUTHTOK holds the TPM-unsealed
# login password. [success=1 default=ignore] skips system-local-login
# (the password prompt) but lets pam_gnome_keyring's auth phase run so
# it can pick up PAM_AUTHTOK and unlock the login keyring.
#
# DO NOT use `sufficient` here — it would skip pam_gnome_keyring's auth
# phase entirely, leaving the keyring locked after face-auth login.

auth       [success=1 default=ignore]   pam_faceauth.so
auth       include      system-local-login
auth       optional     pam_gnome_keyring.so

account    include      system-local-login

password   include      system-local-login
password   optional     pam_gnome_keyring.so use_authtok

session    include      system-local-login
session    optional     pam_gnome_keyring.so auto_start
