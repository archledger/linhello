#%PAM-1.0
#
# Example /etc/pam.d/system-login with linhello face-auth (TTY login).
#
# Face-auth runs first; on success the user is logged in without
# typing a password. Falls through to the normal password flow on
# failure. Useful for headless servers with a USB camera.
#
# Install:
#   sudo cp /etc/pam.d/system-login /etc/pam.d/system-login.bak
#   sudo cp /usr/share/linhello/pam.d/examples/system-login /etc/pam.d/system-login

auth       sufficient   pam_linhello.so
-auth      [success=2 default=ignore]  pam_systemd_home.so
auth       [success=1 default=bad]     pam_unix.so          try_first_pass nullok
auth       [default=die]               pam_faillock.so      authfail
auth       optional                    pam_permit.so
auth       required                    pam_env.so
auth       required                    pam_faillock.so      authsucc

-account   [success=1 default=ignore]  pam_systemd_home.so
account    required                    pam_unix.so
account    optional                    pam_permit.so
account    required                    pam_time.so

-password  [success=1 default=ignore]  pam_systemd_home.so
password   required                    pam_unix.so          try_first_pass nullok shadow
password   optional                    pam_linhello.so
password   optional                    pam_permit.so

-session   optional                    pam_systemd_home.so
session    required                    pam_limits.so
session    required                    pam_unix.so
session    optional                    pam_permit.so
