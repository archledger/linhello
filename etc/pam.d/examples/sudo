#%PAM-1.0
#
# Example /etc/pam.d/sudo with aegyra face-auth.
#
# Face-auth is sufficient (skips the password prompt on success). If the
# camera fails or no face matches, falls through to the normal sudo stack.
#
# WARNING: only deploy this after you have verified `aegyra verify --user
# $USER` works reliably. A broken face-auth path makes sudo painful.

auth       sufficient   pam_faceauth.so
auth       include      system-auth

account    include      system-auth

session    include      system-auth
