# Maintainer: Ben <archledger236@gmail.com>
pkgname=linhello
pkgver=0.3.2
pkgrel=1
pkgdesc="TPM-backed facial authentication and PAM keyring unlock for Linux"
arch=('x86_64')
url="https://github.com/archledger/linhello"
license=('GPL3')
depends=('tpm2-tss' 'pam' 'v4l-utils' 'onnxruntime' 'gcc-libs' 'glibc')
makedepends=('rust' 'cargo' 'clang')
optdepends=('sbctl: secure-boot key enrollment via `linhello secureboot setup`')
install=linhello.install
# Release artifact: ship a single stripped package, no separate -debug split
# (keeps `linhello package`/`update` from having to disambiguate two .pkg.tar.zst).
options=('!debug')

# Clean-chroot-compatible source: we consume a tarball that lives next to
# this PKGBUILD. Produce it from the repo root with:
#
#     make dist
#
# which invokes `git archive` into packaging/arch/linhello-${pkgver}.tar.gz.
# `extra-x86_64-build` copies this tarball into the chroot alongside the
# PKGBUILD, so the build no longer reaches outside $srcdir.
source=("${pkgname}-${pkgver}.tar.gz")
# SKIP is acceptable while the tarball is produced locally from a known
# commit; for AUR publishing, replace with `makepkg -g` output and switch
# `source=` to a GitHub release URL.
sha256sums=('SKIP')

build() {
    cd "$srcdir/${pkgname}-${pkgver}"
    make PREFIX=/usr \
        PAMDIR=/usr/lib/security \
        SYSTEMDDIR=/usr/lib/systemd/system \
        CARGO_TARGET_DIR="$srcdir/target"
}

package() {
    cd "$srcdir/${pkgname}-${pkgver}"
    make install \
        DESTDIR="$pkgdir" \
        PREFIX=/usr \
        PAMDIR=/usr/lib/security \
        SYSTEMDDIR=/usr/lib/systemd/system \
        CARGO_TARGET_DIR="$srcdir/target"

    # SELinux policy sources shipped by `make install` are inert on Arch (no
    # SELinux); drop them so the package stays clean. The sysusers.d group file
    # and systemd unit installed by `make install` are kept as-is.
    rm -rf "$pkgdir/etc/linhello/selinux" "$pkgdir/usr/share/linhello/selinux"

    # Models are not packaged — user installs their own InsightFace buffalo_l
    # weights. Ship an empty config dir and the models README as docs.
    install -dm755 "$pkgdir/etc/linhello"
    install -Dm644 models/README.md "$pkgdir/usr/share/doc/$pkgname/models.md"
}
